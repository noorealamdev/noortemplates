{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "noortemplates/product-tabs",
    "title": "Product Tabs",
    "category": "noortemplates",
    "icon": "editor-table",
    "description": "Displays the current WooCommerce product's description, additional information and reviews tabs.",
    "keywords": [
        "woocommerce",
        "product",
        "tabs",
        "reviews",
        "description"
    ],
    "version": "1.0.0",
    "textdomain": "noortemplates",
    "attributes": {
        "boxed": {
            "type": "boolean",
            "default": true
        },
        "boxedWidth": {
            "type": "number",
            "default": 1200
        }
    },
    "supports": {
        "align": [
            "wide",
            "full"
        ],
        "anchor": true,
        "html": false,
        "color": {
            "background": true,
            "text": true,
            "gradients": true
        },
        "typography": {
            "fontSize": true,
            "__experimentalFontWeight": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        },
        "__experimentalBorder": {
            "radius": true,
            "width": true,
            "color": true
        },
        "shadow": true
    },
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "render": "file:./render.php"
}
