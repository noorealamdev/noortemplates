{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "noortemplates/accordion",
    "title": "Accordion",
    "category": "noortemplates",
    "icon": "menu-alt",
    "description": "Collapsible content panels, perfect for FAQs. Powered by the WordPress Interactivity API — no jQuery, minimal footprint.",
    "keywords": [
        "accordion",
        "faq",
        "toggle",
        "collapse"
    ],
    "version": "1.0.0",
    "textdomain": "noortemplates",
    "attributes": {
        "allowMultiple": {
            "type": "boolean",
            "default": false
        },
        "boxed": {
            "type": "boolean",
            "default": true
        },
        "boxedWidth": {
            "type": "number",
            "default": 800
        }
    },
    "supports": {
        "align": [
            "wide"
        ],
        "anchor": true,
        "html": false,
        "interactivity": true,
        "color": {
            "background": true,
            "text": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        },
        "__experimentalBorder": {
            "radius": true,
            "width": true,
            "color": true
        },
        "shadow": true
    },
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "editorStyle": "file:./index.css",
    "viewScriptModule": "file:./view.js"
}
