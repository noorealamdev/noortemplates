{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "noortemplates/product-breadcrumbs",
    "title": "Product Breadcrumbs",
    "category": "noortemplates",
    "icon": "arrow-right-alt",
    "description": "Displays the WooCommerce breadcrumb trail for the current product.",
    "keywords": [
        "woocommerce",
        "breadcrumbs",
        "navigation"
    ],
    "version": "1.0.0",
    "textdomain": "noortemplates",
    "supports": {
        "anchor": true,
        "html": false,
        "color": {
            "background": true,
            "text": true,
            "gradients": true
        },
        "typography": {
            "fontSize": true,
            "lineHeight": true,
            "__experimentalFontFamily": true,
            "__experimentalFontWeight": true,
            "__experimentalLetterSpacing": true,
            "__experimentalTextTransform": true
        },
        "spacing": {
            "margin": true,
            "padding": true
        },
        "__experimentalBorder": {
            "radius": true,
            "width": true,
            "color": true
        },
        "shadow": true
    },
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "render": "file:./render.php"
}
