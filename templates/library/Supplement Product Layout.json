  "content": "<!-- wp:noortemplates/hero {\"headingFontSize\":\"52px\",\"subheadingFontSize\":\"20px\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"2.78rem\",\"bottom\":\"2.78rem\",\"left\":\"10rem\",\"right\":\"10rem\"},\"margin\":{\"right\":\"0\",\"left\":\"0\"}},\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|ast-global-color-4\"}}},\"color\":{\"gradient\":\"linear-gradient(79deg,rgb(27,132,115) 0%,rgb(69,209,186) 100%)\"}},\"textColor\":\"ast-global-color-4\"} -->\n<div class=\"wp-block-noortemplates-hero alignfull has-text-align-center has-ast-global-color-4-color has-text-color has-background has-link-color\" style=\"background:linear-gradient(79deg,rgb(27,132,115) 0%,rgb(69,209,186) 100%);margin-right:0;margin-left:0;padding-top:2.78rem;padding-right:10rem;padding-bottom:2.78rem;padding-left:10rem\"><div class=\"noortemplates-hero__content is-boxed\" style=\"max-width:700px\"><h1 class=\"noortemplates-hero__heading\" style=\"font-size:52px\"><strong>Defend Your <em>Shield</em></strong></h1><p class=\"noortemplates-hero__subheading\" style=\"font-size:20px\">84% of your daily energy is drained when your immune system is compromised†. Most people don’t realize their defense is failing until it’s already too late. These science-backed ingredients provide the emergency support you’re missing:</p><div class=\"noortemplates-hero__actions\"><!-- wp:noortemplates/button {\"url\":\"#\",\"style\":{\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|ast-global-color-2\"}}}},\"backgroundColor\":\"ast-global-color-5\",\"textColor\":\"ast-global-color-2\"} -->\n<div class=\"wp-block-noortemplates-button\"><a class=\"wp-block-noortemplates-button noortemplates-button__link has-ast-global-color-2-color has-ast-global-color-5-background-color has-text-color has-background has-link-color\" href=\"#\"><strong>BUY NOW</strong></a></div>\n<!-- /wp:noortemplates/button --></div></div></div>\n<!-- /wp:noortemplates/hero -->\n\n<!-- wp:spacer {\"height\":\"57px\"} -->\n<div style=\"height:57px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n<!-- /wp:spacer -->\n\n<!-- wp:noortemplates/review-carousel {\"productId\":139,\"selectedReviews\":[18,17,16,15,14]} /-->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"left\":\"var:preset|spacing|50\",\"right\":\"var:preset|spacing|50\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"1200px\"}} -->\n<div class=\"wp-block-group\" style=\"padding-right:var(--wp--preset--spacing--50);padding-left:var(--wp--preset--spacing--50)\"><!-- wp:spacer {\"height\":\"57px\"} -->\n<div style=\"height:57px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n<!-- /wp:spacer -->\n\n<!-- wp:columns {\"style\":{\"spacing\":{\"padding\":{\"right\":\"0\",\"left\":\"0\"}}}} -->\n<div class=\"wp-block-columns\" style=\"padding-right:0;padding-left:0\"><!-- wp:column -->\n<div class=\"wp-block-column\"><!-- wp:noortemplates/product-gallery-carousel /--></div>\n<!-- /wp:column -->\n\n<!-- wp:column {\"style\":{\"spacing\":{\"blockGap\":\"0.5rem\"}}} -->\n<div class=\"wp-block-column\"><!-- wp:noortemplates/product-category /-->\n\n<!-- wp:noortemplates/product-title {\"style\":{\"spacing\":{\"margin\":{\"top\":\"0.25rem\"}}},\"fontSize\":\"large\"} /-->\n\n<!-- wp:noortemplates/product-rating {\"style\":{\"spacing\":{\"margin\":{\"top\":\"0.25rem\"}}}} /-->\n\n<!-- wp:noortemplates/product-price {\"style\":{\"typography\":{\"fontWeight\":\"700\"},\"spacing\":{\"margin\":{\"top\":\"0.25rem\"}}},\"fontSize\":\"large\"} /-->\n\n<!-- wp:noortemplates/product-short-description {\"style\":{\"spacing\":{\"margin\":{\"top\":\"0.25rem\"}}}} /-->\n\n<!-- wp:noortemplates/product-add-to-cart {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|30\",\"bottom\":\"var:preset|spacing|30\"}}}} /-->\n\n<!-- wp:noortemplates/icon-list {\"rows\":[{\"icon\":\"shipping\",\"text\":\"Free Shipping and Exchanges\"},{\"icon\":\"nt-shieldCheck\",\"text\":\"Flexible and Secure Payment, Pay on Delivery\"},{\"icon\":\"thumbsUp\",\"text\":\"600,000 Happy Customers\"}],\"fontSize\":\"medium\"} /-->\n\n<!-- wp:noortemplates/trust-badges {\"items\":[{\"icon\":\"nt-shieldCheck\",\"label\":\"Third-Party Tested\"},{\"icon\":\"nt-leaf\",\"label\":\"No Artificial\"},{\"icon\":\"nt-capsule\",\"label\":\"Vegan Friendly\"},{\"icon\":\"nt-medal\",\"label\":\"GMP Certified\"}]} /--></div>\n<!-- /wp:column --></div>\n<!-- /wp:columns --></div>\n<!-- /wp:group -->\n\n<!-- wp:spacer {\"height\":\"57px\"} -->\n<div style=\"height:57px\" aria-hidden=\"true\" class=\"wp-block-spacer\"></div>\n<!-- /wp:spacer -->\n\n<!-- wp:group {\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|80\",\"bottom\":\"var:preset|spacing|80\",\"left\":\"0\",\"right\":\"0\"}},\"color\":{\"gradient\":\"linear-gradient(135deg,rgb(27,39,36) 0%,rgb(43,185,185) 100%)\"}},\"layout\":{\"type\":\"constrained\",\"justifyContent\":\"center\"}} -->\n<div class=\"wp-block-group has-background\" style=\"background:linear-gradient(135deg,rgb(27,39,36) 0%,rgb(43,185,185) 100%);padding-top:var(--wp--preset--spacing--80);padding-right:0;padding-bottom:var(--wp--preset--spacing--80);padding-left:0\"><!-- wp:media-text {\"mediaId\":149,\"mediaLink\":\"http://localhost/noorblocks/?attachment_id=149\",\"linkDestination\":\"none\",\"mediaType\":\"image\"} -->\n<div class=\"wp-block-media-text is-stacked-on-mobile\"><figure class=\"wp-block-media-text__media\"><img src=\"noortemplates-bundled-asset:templates/library/assets/ingredients.webp\" alt=\"\" class=\"wp-image-149 size-full\"/></figure><div class=\"wp-block-media-text__content\"><!-- wp:heading {\"level\":6,\"style\":{\"elements\":{\"link\":{\"color\":{\"text\":\"var:preset|color|ast-global-color-5\"}}}},\"textColor\":\"ast-global-color-5\"} -->\n<h6 class=\"wp-block-heading has-ast-global-color-5-color has-text-color has-link-color\"><br><strong>CLINICALLY FORMULATED</strong></h6>\n<!-- /wp:heading -->\n\n<!-- wp:noortemplates/heading {