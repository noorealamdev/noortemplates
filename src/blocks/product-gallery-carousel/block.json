{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "noortemplates/product-gallery-carousel",
	"title": "Product Gallery Carousel",
	"category": "noortemplates",
	"icon": "images-alt2",
	"description": "A swipeable carousel of the current WooCommerce product's own images, with an optional thumbnail strip.",
	"keywords": [ "woocommerce", "product", "gallery", "images", "carousel", "slider" ],
	"version": "1.0.0",
	"textdomain": "noortemplates",
	"attributes": {
		"showThumbnails": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true
		},
		"shadow": true
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
