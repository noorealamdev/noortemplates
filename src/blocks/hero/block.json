{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "noortemplates/hero",
	"title": "Hero",
	"category": "noortemplates",
	"icon": "cover-image",
	"description": "A full-width hero section with a heading, subheading, call-to-action button and optional background image.",
	"keywords": [ "hero", "banner", "section", "cover" ],
	"version": "1.0.0",
	"textdomain": "noortemplates",
	"attributes": {
		"heading": {
			"type": "string",
			"source": "html",
			"selector": ".noortemplates-hero__heading",
			"default": "Your Hero Heading"
		},
		"subheading": {
			"type": "string",
			"source": "html",
			"selector": ".noortemplates-hero__subheading",
			"default": ""
		},
		"backgroundImage": {
			"type": "object",
			"default": {
				"url": "",
				"id": 0
			}
		},
		"textAlign": {
			"type": "string",
			"default": "center"
		},
		"headingFontSize": {
			"type": "string",
			"default": ""
		},
		"subheadingFontSize": {
			"type": "string",
			"default": ""
		},
		"align": {
			"type": "string",
			"default": "full"
		},
		"style": {
			"type": "object",
			"default": {
				"spacing": {
					"padding": {
						"top": "5rem",
						"right": "1.5rem",
						"bottom": "5rem",
						"left": "1.5rem"
					}
				}
			}
		}
	},
	"supports": {
		"align": [ "wide", "full" ],
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true,
			"enableContrastChecker": false
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true
		},
		"shadow": true
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css"
}
