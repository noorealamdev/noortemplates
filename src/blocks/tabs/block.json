{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "noorblocks/tabs",
	"title": "Tabs",
	"category": "noorblocks",
	"icon": "table-row-after",
	"description": "Organize content into switchable tabs. Powered by the WordPress Interactivity API with full keyboard support.",
	"keywords": [ "tabs", "tabbed", "toggle" ],
	"version": "1.0.0",
	"textdomain": "noorblocks",
	"supports": {
		"align": [ "wide" ],
		"anchor": true,
		"html": false,
		"interactivity": true,
		"color": {
			"background": true,
			"text": true
		},
		"spacing": {
			"margin": true,
			"padding": true
		}
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"editorStyle": "file:./index.css",
	"render": "file:./render.php",
	"viewScriptModule": "file:./view.js"
}
