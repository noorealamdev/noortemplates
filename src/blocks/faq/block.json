{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "noortemplates/faq",
    "title": "FAQ Accordion",
    "category": "noortemplates",
    "icon": "editor-help",
    "description": "A collapsible list of frequently asked questions about the product.",
    "keywords": [
        "faq",
        "questions",
        "accordion",
        "section"
    ],
    "version": "1.0.0",
    "textdomain": "noortemplates",
    "attributes": {
        "title": {
            "type": "string",
            "source": "html",
            "selector": "h2",
            "default": "Frequently Asked Questions"
        },
        "align": {
            "type": "string"
        },
        "boxed": {
            "type": "boolean",
            "default": true
        },
        "boxedWidth": {
            "type": "number",
            "default": 800
        },
        "style": {
            "type": "object",
            "default": {
                "spacing": {
                    "padding": {
                        "top": "4rem",
                        "right": "1.5rem",
                        "bottom": "4rem",
                        "left": "1.5rem"
                    }
                }
            }
        }
    },
    "supports": {
        "align": [
            "wide",
            "full"
        ],
        "anchor": true,
        "html": false,
        "color": {
            "background": true,
            "text": true,
            "gradients": true
        },
        "typography": {
            "fontSize": true
        },
        "spacing": {
            "margin": true,
            "padding": true,
            "blockGap": true
        },
        "__experimentalBorder": {
            "radius": true,
            "width": true,
            "color": true
        },
        "shadow": true
    },
    "editorScript": "file:./index.js",
    "style": "file:./style-index.css",
    "editorStyle": "file:./index.css"
}
