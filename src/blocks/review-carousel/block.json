{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "noortemplates/review-carousel",
	"title": "Review Carousel",
	"category": "noortemplates",
	"icon": "slides",
	"description": "A curated, swipeable carousel of hand-picked reviews for a chosen product.",
	"keywords": [ "woocommerce", "review", "carousel", "testimonials" ],
	"version": "1.0.0",
	"textdomain": "noortemplates",
	"attributes": {
		"productId": {
			"type": "number",
			"default": 0
		},
		"selectedReviews": {
			"type": "array",
			"default": [],
			"items": {
				"type": "number"
			}
		},
		"boxed": {
			"type": "boolean",
			"default": true
		},
		"boxedWidth": {
			"type": "number",
			"default": 1200
		}
	},
	"supports": {
		"anchor": true,
		"html": false,
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true
		},
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"__experimentalBorder": {
			"radius": true,
			"width": true,
			"color": true
		},
		"shadow": true
	},
	"editorScript": "file:./index.js",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js",
	"render": "file:./render.php"
}
